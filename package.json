{
  "name": "arqiva",
  "version": "1.0.0",
  "description": "ARQIVA Architecture & Design Studio",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "setup": "bash setup.sh",
    "install:all": "bash setup.sh",
