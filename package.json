{
  "name": "arqiva",
  "version": "1.0.0",
  "description": "ARQIVA Architecture & Design Studio",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "setup": "bash setup.sh",
    "build:backend": "cd backend && ./node_modules/.bin/tsc -p tsconfig.json",
    "build:frontend": "cd frontend && ./node_modules/.bin/vite build",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "node backend/dist/index.js",
    "dev": "node backend/dist/index.js"
  }
}
