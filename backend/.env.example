# ─── Database ────────────────────────────────────────────────────────────────
# On Replit: add as a Secret named DATABASE_URL
# Use Neon (neon.tech), Supabase, or Railway for a free hosted PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/arqiva_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# ─── Cloudinary (optional - for image uploads) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@arqivastudio.com

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT is set automatically by Replit — do not override it in Replit Secrets
PORT=3000
NODE_ENV=production
# On Replit, FRONTEND_URL is not needed (frontend served by Express)
FRONTEND_URL=https://your-replit-app.replit.app

# ─── Admin ───────────────────────────────────────────────────────────────────
# These are only used by the seed script
ADMIN_EMAIL=admin@arqivastudio.com
ADMIN_PASSWORD=Admin@123456

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Replit
REPLIT_DEPLOYMENT=false
